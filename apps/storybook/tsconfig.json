{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@ghs-hazard-pictograms/core": ["../../packages/@ghs-hazard-pictograms/core/src/index.ts"],
      "@ghs-hazard-pictograms/react": ["../../packages/@ghs-hazard-pictograms/react/src/index.ts"]
    }
  },
  "include": ["src/**/*", ".storybook/**/*"],
  "exclude": ["node_modules"]
}
