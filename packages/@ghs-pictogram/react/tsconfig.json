{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@ghs-pictogram/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**/*", "node_modules"]
}
