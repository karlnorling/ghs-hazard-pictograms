{
  "name": "@ghs-hazard-pictograms/react",
  "version": "1.0.5",
  "description": "GHS hazard pictogram React components",
  "keywords": [
    "adr",
    "chemical",
    "components",
    "ghs",
    "globally-harmonized-system",
    "hazard",
    "icons",
    "pictogram",
    "pictograms",
    "react",
    "safety",
    "svg",
    "symbol",
    "transport",
    "ui",
    "un",
    "warning"
  ],
  "homepage": "https://karlnorling.github.io/ghs-hazard-pictograms/",
  "bugs": {
    "url": "https://github.com/karlnorling/ghs-hazard-pictograms/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/karlnorling/ghs-hazard-pictograms",
    "directory": "packages/@ghs-hazard-pictograms/react"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'})); require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
    "test": "jest",
    "type-check": "tsc --noEmit -p tsconfig.cjs.json"
  },
  "dependencies": {
    "@ghs-hazard-pictograms/core": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
